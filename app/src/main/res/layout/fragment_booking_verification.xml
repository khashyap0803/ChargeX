<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Booking Verification"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ECDSA Digital Signature (SHA256withECDSA • secp256r1)"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp" />

        <!-- ═══════════════════════════════════════════ -->
        <!-- OFFLINE CREDIT CARD -->
        <!-- ═══════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOfflineCredit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#E3F2FD">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ Offline Emergency Credit"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvCreditBalance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹300"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="#0D47A1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Post-paid Credit"
                            android:textSize="12sp"
                            android:textColor="#1565C0" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/tvChargingHours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="~6.0 hrs"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#2E7D32" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Est. Charging Time"
                            android:textSize="12sp"
                            android:textColor="#388E3C"
                            android:gravity="end" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="(@ ₹50/hr avg L2)"
                            android:textSize="10sp"
                            android:textColor="#66BB6A"
                            android:gravity="end" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Mode Toggle -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:tabMode="fixed"
                app:tabGravity="fill"
                app:tabIndicatorColor="@color/colorPrimary">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 User Mode" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ Station Mode" />
            </com.google.android.material.tabs.TabLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════ -->
        <!-- USER MODE: Generate Booking -->
        <!-- ═══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutUserMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Station ID Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="Station ID"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStationId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="HYD_HITEC_01"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Credit Amount Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="Offline Credit (₹)"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCreditAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="300"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Validity Duration -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Validity (minutes)"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etValidity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="60"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Generate Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateBooking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔐 Generate Signed Trust Token"
                android:textAllCaps="false"
                app:cornerRadius="8dp"
                android:layout_marginBottom="16dp" />

            <!-- QR Code Display -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQrCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardElevation="4dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔏 ECDSA-Signed Trust Token QR"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <ImageView
                        android:id="@+id/ivQrCode"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_marginBottom="12dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="QR Code" />

                    <TextView
                        android:id="@+id/tvQrPayload"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:textColor="?android:attr/textColorSecondary"
                        android:maxLines="3"
                        android:ellipsize="end" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════ -->
        <!-- STATION MODE: Verify Booking -->
        <!-- ═══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutStationMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Verify a booking QR code to authenticate offline. No internet required."
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="16dp" />

            <!-- Camera Scan Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanQr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📷 Scan QR Code (Camera)"
                android:textAllCaps="false"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_search"
                android:layout_marginBottom="8dp" />

            <!-- Upload QR Image Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUploadQrImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🖼️ Upload QR Image"
                android:textAllCaps="false"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="8dp"
                android:layout_marginBottom="16dp" />

            <!-- Manual Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Paste QR payload (for testing)"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etManualQr"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="2" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Action Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerifyManual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔍 Verify Pasted Code"
                android:textAllCaps="false"
                app:cornerRadius="8dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerifyLastGenerated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✅ Verify Last Generated Token"
                android:textAllCaps="false"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="8dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTestTampered"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ Test Tampered Booking"
                android:textAllCaps="false"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="8dp"
                app:strokeColor="#FF5722"
                android:textColor="#FF5722"
                android:layout_marginBottom="16dp" />
        </LinearLayout>

        <!-- ═══════════════════════════════════════════ -->
        <!-- VERIFICATION RESULT CARD -->
        <!-- ═══════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardElevation="6dp"
            app:cardCornerRadius="16dp"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvResultIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="48sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvResultTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvResultDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:gravity="center" />

                <!-- Ticket Details (shown only for Valid/Expired) -->
                <LinearLayout
                    android:id="@+id/layoutTicketDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/rounded_background"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvBookingId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tvStationId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tvUserId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tvExpiry"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════ -->
        <!-- CHARGING SESSION TIMER -->
        <!-- ═══════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardChargingTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardElevation="6dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1A237E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ Charging Session"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#9FA8DA"
                    android:layout_marginBottom="12dp" />

                <!-- Timer Display -->
                <TextView
                    android:id="@+id/tvTimerDisplay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <!-- Running Cost -->
                <TextView
                    android:id="@+id/tvRunningCost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="₹0.00"
                    android:textSize="24sp"
                    android:textColor="#FFD54F"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <!-- Start / Stop Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartCharging"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="▶ Start Charging"
                        app:backgroundTint="#4CAF50" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStopCharging"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="⏹ Stop"
                        android:visibility="gone"
                        app:backgroundTint="#F44336" />
                </LinearLayout>

                <!-- Session Summary -->
                <TextView
                    android:id="@+id/tvSessionSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#C5CAE9"
                    android:fontFamily="monospace"
                    android:visibility="gone"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

        <!-- Back Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="← Back to Map"
            android:textAllCaps="false"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
